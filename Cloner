local P, V = game:GetService("Players").LocalPlayer, game:GetService("VirtualInputManager")
local pGui = P:WaitForChild("PlayerGui")

-- 1. Check if GUI already exists to maintain state/prevent duplicates
local s = pGui:FindFirstChild("QuantumCloneGui")
if not s then
    s = Instance.new("ScreenGui")
    s.Name = "QuantumCloneGui"
    s.Parent = pGui
    s.ResetOnSpawn = false -- This prevents the GUI from disappearing on reset
end

-- 2. Create the Button if it doesn't exist
local b = s:FindFirstChild("CloneButton")
if not b then
    b = Instance.new("TextButton", s)
    b.Name = "CloneButton"
    b.Size, b.Position, b.Text = UDim2.new(0, 80, 0, 30), UDim2.new(0.85, 0, 0.53, 0), "Clone"
end

-- 3. Logic Execution
b.MouseButton1Click:Connect(function()
    local c = P.Character
    local t = P.Backpack:FindFirstChild("Quantum Cloner") or (c and c:FindFirstChild("Quantum Cloner"))
    
    if t and c:FindFirstChild("Humanoid") then
        c.Humanoid:EquipTool(t)
        task.wait(0.1)
        
        local v = workspace.CurrentCamera.ViewportSize
        
        -- Click 1
        V:SendMouseButtonEvent(v.X/2, v.Y/2, 0, true, game, 1)
        task.wait(0.05)
        V:SendMouseButtonEvent(v.X/2, v.Y/2, 0, false, game, 1)
        
        task.wait(0.2)
        
        -- Click 2
        V:SendMouseButtonEvent(v.X*0.54, v.Y*0.72, 0, true, game, 1)
        task.wait(0.05)
        V:SendMouseButtonEvent(v.X*0.54, v.Y*0.72, 0, false, game, 1)
    end
end)
